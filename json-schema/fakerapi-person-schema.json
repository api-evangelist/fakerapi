{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakerapi.it/schemas/person.json",
  "title": "Person",
  "description": "A fake person profile produced by FakerAPI /api/v1/persons.",
  "type": "object",
  "properties": {
    "id": { "type": "integer", "example": 1 },
    "firstname": { "type": "string", "example": "Urban" },
    "lastname": { "type": "string", "example": "Donnelly" },
    "email": { "type": "string", "format": "email", "example": "urban.donnelly@example.org" },
    "phone": { "type": "string", "example": "+14252384998" },
    "birthday": { "type": "string", "format": "date", "example": "1985-04-12" },
    "gender": { "type": "string", "enum": ["male", "female"], "example": "male" },
    "website": { "type": "string", "format": "uri", "example": "http://donnelly.example.com" },
    "image": { "type": "string", "format": "uri", "example": "http://placeimg.com/640/480/people" },
    "address": { "$ref": "fakerapi-address-schema.json" }
  },
  "required": ["id", "firstname", "lastname", "email"]
}
